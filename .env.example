APP_NAME="BITSI Dispatch"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-production-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# --- Production Logging (use "error" or "warning" in production, never "debug") ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database Configuration ---
# Recommended: MySQL for production
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bitsi_dispatch
DB_USERNAME=root
DB_PASSWORD=

# --- Session Configuration ---
# "file" is faster than "database" for most deployments
# Use "redis" if available for even better performance
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Enable secure cookies in production (requires HTTPS)
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# --- Cache Configuration ---
# "file" is faster than "database" in most scenarios
# Use "redis" if available for best performance
CACHE_STORE=file

# --- Mail Configuration ---
# Use SMTP for production (e.g., Mailgun, SendGrid, Amazon SES)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=your-email@your-domain.com
MAIL_PASSWORD=your-email-password
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Semaphore SMS (Philippine SMS Provider)
# Get your API key from https://semaphore.co
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=BITSI

VITE_APP_NAME="${APP_NAME}"